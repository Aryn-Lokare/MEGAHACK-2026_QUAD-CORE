generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  role      Role       @default(STUDENT)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
}

model Course {
  id                String   @id @default(uuid())
  name              String
  title             String?
  department        String
  googleClassroomId String?  @unique
  facultyId         String?
  createdAt         DateTime @default(now())
  assignments       Assignment[]
}

model Activity {
  id        String   @id @default(uuid())
  type      String
  userId    String
  createdAt DateTime @default(now())
}

model Assignment {
  id                 String   @id @default(uuid())
  title              String
  subject            String?
  description        String?
  deadline           DateTime?
  status             String
  userId             String?
  courseId           String?
  googleCourseWorkId String?  @unique
  course             Course?  @relation(fields: [courseId], references: [id])
  submissions        Submission[]
  createdAt          DateTime @default(now())
}

model Submission {
  id                 String   @id @default(uuid())
  assignmentId       String
  userId             String?
  studentEmail       String
  googleSubmissionId String?  @unique
  grade             Float?
  status             String
  late               Boolean  @default(false)
  submittedAt        DateTime?
  assignment         Assignment @relation(fields: [assignmentId], references: [id])
  createdAt          DateTime @default(now())
}

model Prediction {
  id             String   @id @default(uuid())
  studentId      String
  riskLevel      String
  predictedGrade String
  recommendation String?
  createdAt      DateTime @default(now())
}

model CampusKnowledge {
  id      String @id @default(uuid())
  title   String @unique
  content String
}

model CampusLocation {
  id       String @id @default(uuid())
  name     String
  building String
  floor    Int
}

model Student {
  id         String @id @default(uuid())
  name       String
  email      String @unique
  department String
  attendance Int
}

model Timetable {
  id      String @id @default(uuid())
  subject String
  room    String
  time    String
  day     String
}

enum Role {
  ADMIN
  FACULTY
  STUDENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}
